<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ProductAI — AI Product Analyzer</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<style>
/* ---------------- CSS INTEGRAL ---------------- */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--primary:#6C3FE8;--primary-dark:#5230C5;--accent:#FF5C5C;--accent2:#00C9A7;--bg:#0D0F1A;--bg2:#13152A;--bg3:#1A1D35;--text:#F0F2FF;--muted:#8B90B8;--card:#1E2140;--border:#2E3260;--gold:#FFD166}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);line-height:1.6;overflow-x:hidden}
/* ---- NAV ---- */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:1rem 5%;background:rgba(13,15,26,.9);backdrop-filter:blur(14px);border-bottom:1px solid var(--border)}
.nav-logo{display:flex;align-items:center;gap:.5rem;font-weight:800;font-size:1.15rem;color:var(--text);text-decoration:none}
.nav-links{display:flex;gap:2rem}
.nav-links a{color:var(--muted);text-decoration:none;font-size:.9rem;transition:color .2s}
.nav-links a:hover{color:var(--text)}
.nav-cta{background:var(--primary);color:#fff;border:none;padding:.55rem 1.4rem;border-radius:50px;font-weight:600;font-size:.9rem;cursor:pointer;text-decoration:none;transition:background .2s,transform .15s}
.nav-cta:hover{background:var(--primary-dark);transform:scale(1.04)}
@media(max-width:768px){.nav-links{display:none}}

/* ---- HERO / ANALYZER ---- */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:120px 5% 80px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(108,63,232,.35) 0%,transparent 70%);pointer-events:none}
.hero-badge{display:inline-flex;align-items:center;gap:.5rem;background:rgba(108,63,232,.18);border:1px solid rgba(108,63,232,.4);color:#B69AFF;padding:.4rem 1.1rem;border-radius:50px;font-size:.8rem;font-weight:600;margin-bottom:1.5rem;letter-spacing:.04em;text-transform:uppercase}
.hero h1{font-size:clamp(2.2rem,5.5vw,4.5rem);font-weight:900;line-height:1.1;max-width:820px;margin-bottom:1.2rem}
.hero h1 .highlight{background:linear-gradient(90deg,#B69AFF,#FF5C5C);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero p{font-size:clamp(1rem,2.2vw,1.2rem);color:var(--muted);max-width:580px;margin-bottom:2.5rem}
.analyzer-box{background:var(--card);border:1px solid var(--border);border-radius:24px;padding:2rem 2.2rem;max-width:680px;width:100%;text-align:left;box-shadow:0 24px 80px rgba(0,0,0,.5);position:relative;z-index:1}
.analyzer-label{font-size:.72rem;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin-bottom:.8rem;font-weight:700}
.input-row{display:flex;gap:.75rem;margin-bottom:.8rem}
.product-input{flex:1;background:var(--bg3);border:1.5px solid var(--border);border-radius:12px;padding:.8rem 1.1rem;color:var(--text);font-size:.9rem;font-family:'Inter',sans-serif;outline:none;transition:border-color .2s}
.product-input:focus{border-color:var(--primary)}
.product-input::placeholder{color:var(--muted)}
.analyze-btn{background:var(--primary);color:#fff;border:none;padding:.8rem 1.6rem;border-radius:12px;font-weight:700;font-size:.9rem;cursor:pointer;white-space:nowrap;transition:background .2s,transform .15s,box-shadow .2s;box-shadow:0 4px 20px rgba(108,63,232,.4)}
.analyze-btn:hover{background:var(--primary-dark);transform:translateY(-1px);box-shadow:0 6px 28px rgba(108,63,232,.5)}
.analyze-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}
.examples-row{display:flex;gap:.5rem;flex-wrap:wrap}
.ex-chip{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:.3rem .75rem;font-size:.72rem;color:var(--muted);cursor:pointer;transition:border-color .2s,color .2s}
.ex-chip:hover{border-color:var(--primary);color:var(--text)}
.credits-info{font-size:.72rem;color:var(--muted);margin-top:.7rem;text-align:right}
.credits-info span{color:var(--accent2);font-weight:700}
/* ---- RESULT PANEL ---- */
#result-panel{display:none;margin-top:1.5rem;animation:fadeUp .5s ease}
#result-panel.show{display:block}
.result-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem;flex-wrap:wrap;gap:.8rem}
.result-product-name{font-weight:800;font-size:1.05rem}
.result-product-url{font-size:.75rem;color:var(--muted);word-break:break-all}
.verdict-badge{display:inline-flex;align-items:center;gap:.4rem;padding:.35rem .9rem;border-radius:50px;font-size:.8rem;font-weight:700}
.verdict-good{background:rgba(0,201,167,.15);color:var(--accent2);border:1px solid rgba(0,201,167,.3)}
.verdict-bad{background:rgba(255,92,92,.15);color:var(--accent);border:1px solid rgba(255,92,92,.3)}
.verdict-mid{background:rgba(255,209,102,.15);color:var(--gold);border:1px solid rgba(255,209,102,.3)}
/* ---- TAB CONTENTS ---- */
.tab-pane{display:none;animation:fadeUp .3s ease}
.tab-pane.active{display:block}
.rtab{background:none;border:none;color:var(--muted);font-size:.83rem;font-weight:600;cursor:pointer;padding:.3rem .8rem;border-radius:8px;transition:background .2s,color .2s;font-family:'Inter',sans-serif}
.rtab.active{background:rgba(108,63,232,.2);color:var(--text)}
/* ---- ANIMS ---- */
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.fade-up{animation:fadeUp .7s ease both}
.delay-1{animation-delay:.15s}.delay-2{animation-delay:.3s}.delay-3{animation-delay:.45s}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a class="nav-logo" href="#">🤖 ProductAI</a>
  <div class="nav-links">
    <a href="#how-it-works">How it works</a>
    <a href="#features">Features</a>
    <a href="#pricing">Pricing</a>
    <a href="#testimonials">Testimonials</a>
  </div>
  <a href="#" class="nav-cta" onclick="openModal();return false">Try Premium →</a>
</nav>

<!-- HERO / ANALYZER -->
<section class="hero">
  <div class="hero-badge fade-up">✨ Powered by AI</div>
  <h1 class="fade-up delay-1">Find out if your product<br/><span class="highlight">is worth selling</span><br/>in seconds</h1>
  <p class="fade-up delay-2">Paste any product link or description and our AI tells you if it's profitable.</p>
  <div class="analyzer-box fade-up delay-3">
    <div class="analyzer-label">🔍 Analyze a product</div>
    <div class="input-row">
      <input class="product-input" id="productInput" type="text" placeholder="Paste product URL or description"/>
      <button class="analyze-btn" id="analyzeBtn" onclick="startAnalysis()">Analyze →</button>
    </div>
    <div class="credits-info">Free plan: <span id="creditsLeft">3</span> analyses remaining today</div>
    <div id="result-panel">
      <div id="tab-overview" class="tab-pane active">Result will show here...</div>
    </div>
  </div>
</section>

<script>
/* -------- JS INLINE -------- */
let credits = 3;
let isPremium = false;
function startAnalysis() {
  const input = document.getElementById('productInput').value;
  if(!input){ alert('Enter a product!'); return; }
  if(credits<=0 && !isPremium){ alert('Upgrade to Premium!'); return; }
  credits--; document.getElementById('creditsLeft').textContent=credits;
  document.getElementById('result-panel').style.display='block';
  document.getElementById('tab-overview').textContent='Analyzing "'+input+'"... (mock result)';
}
function openModal(){ alert('Modal would open here (mock)'); }
</script>

</body>
</html>
