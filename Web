    risks:['Sizing accuracy critical — returns common for wrong fit','Pet product ads must avoid misleading safety claims','Competitive pet products market','Requires clear sizing guide to reduce support tickets'],
    adFacebook:'🐾 Your dog deserves to ride safe. Our crash-tested car harness keeps your best friend secure on every trip. 5,000+ happy pet parents — shop now!',
    adTiktok:'Taking your dog on a road trip? You NEED this 🐶🚗 #dogsoftiktok #petsafety #roadtrip #dogmom',
    adInstagram:'Every car trip with your pup should be safe AND comfortable 🐾❤️ Shop our adjustable safety harness — link in bio.',
    strategies:['Target dog owner communities and Facebook pet groups','Leverage TikTok dog content — pet videos have massive organic reach','Offer size guide and fit guarantee to reduce purchase hesitation','Bundle with travel water bottle or poop bag dispenser']
  }
];

const genericAnalysis = {
  score: null, // generated dynamically
  demand: null,
  competition: null,
  margin: null,
  price: null,
  audience: null,
  trend: null,
  risks: ['Validate supplier quality before scaling ad spend','Check platform policies for advertising restrictions','Analyze top competitors\' pricing before setting your own','Seasonal demand swings may affect consistency'],
  adFacebook: null,
  adTiktok: null,
  adInstagram: null,
  strategies: ['Start with a small test budget ($5–$10/day) before scaling','Use Facebook Audience Insights to refine targeting','A/B test 2–3 creatives simultaneously to find the winner','Monitor ROAS weekly and cut underperforming ad sets']
};

function getAnalysisData(input) {
  const lower = input.toLowerCase();
  for (const p of productDB) {
    if (p.keywords.some(k => lower.includes(k))) return { ...p };
  }
  // Generic AI-simulated result
  const score = Math.floor(Math.random() * 35) + 50; // 50-85
  const demands = ['🔥 Very High','🔥 High','🟢 Moderate','🟡 Low-Medium'];
  const comps   = ['🔴 High','🟡 Medium','🟢 Low'];
  const margins = ['$8–$14','$12–$20','$15–$25','$20–$35'];
  const prices  = ['$19.99–$29.99','$24.99–$39.99','$34.99–$49.99','$44.99–$69.99'];
  const audiences = ['18–35 yr olds, online shoppers','25–45 yr olds, professionals','Teens & young adults 16–28','Parents 30–50 with families'];
  const trends  = ['📈 Growing','📊 Stable','📉 Declining slightly','🚀 Trending now'];
  const ri = Math.floor(Math.random()*4);
  const ci = score > 70 ? Math.floor(Math.random()*2) : Math.floor(Math.random()*2)+1;
  const words = input.replace(/https?:\/\/[^\s]+/g,'').trim();
  const cleanName = words.length > 3
    ? words.charAt(0).toUpperCase() + words.slice(1)
    : 'Analyzed Product';
  return {
    name: cleanName,
    score,
    verdict: score >= 70 ? 'good' : score >= 50 ? 'mid' : 'bad',
    demand: demands[ri], competition: comps[ci],
    margin: margins[ri], price: prices[ri],
    audience: audiences[Math.floor(Math.random()*4)],
    trend: trends[Math.floor(Math.random()*4)],
    risks: genericAnalysis.risks,
    adFacebook: `🛍️ Tired of overpaying? Our ${cleanName.toLowerCase()} is exactly what you've been looking for. Premium quality, unbeatable price. Shop now — free shipping on orders over $30!`,
    adTiktok: `I found the most underrated product on the internet 👀 #${cleanName.toLowerCase().replace(/\s+/g,'')} #dropshipping #ecommerce #tiktokmademebuyit`,
    adInstagram: `Upgrade your everyday with our ${cleanName} ✨ Quality you can feel, price you'll love. Tap the link in bio to shop.`,
    strategies: genericAnalysis.strategies
  };
}

// ── ANALYSIS FLOW ──
async function startAnalysis() {
  const input = document.getElementById('productInput').value.trim();
  if (!input) { showToast('⚠️ Please enter a product URL or description','error'); return; }
  if (credits <= 0 && !isPremium) { openModal(); return; }

  document.getElementById('analyzeBtn').disabled = true;
  document.getElementById('result-panel').classList.remove('show');
  const loader = document.getElementById('loaderWrap');
  loader.classList.add('active');

  // Animate progress bar
  const fill = document.getElementById('loaderFill');
  const steps = [0,1,2,3,4];
  const durations = [400,600,700,500,800];
  let progress = 0;
  for (let i = 0; i < steps.length; i++) {
    document.getElementById('step'+i).classList.add('active');
    progress += 100/steps.length;
    fill.style.width = progress + '%';
    await sleep(durations[i]);
    document.getElementById('step'+i).classList.remove('active');
    document.getElementById('step'+i).classList.add('done');
  }
  fill.style.width = '100%';
  await sleep(300);

  loader.classList.remove('active');
  steps.forEach(i => { document.getElementById('step'+i).classList.remove('done','active'); });
  fill.style.width = '0%';

  const data = getAnalysisData(input);
  renderResult(data, input);
  analysisCount++;

  if (!isPremium) {
    credits--;
    document.getElementById('creditsLeft').textContent = credits;
  }
  document.getElementById('analyzeBtn').disabled = false;
  showToast('✅ Analysis complete!','success');
}

function sleep(ms){ return new Promise(r=>setTimeout(r,ms)); }

function renderResult(data, input) {
  // Name & URL
  document.getElementById('r-name').textContent = data.name || input;
  document.getElementById('r-url').textContent = input.startsWith('http') ? input.slice(0,55)+(input.length>55?'...':'') : '';

  // Verdict badge
  const vb = document.getElementById('r-verdict');
  if (data.verdict === 'good') { vb.className='verdict-badge verdict-good'; vb.textContent='✅ Profitable'; }
  else if (data.verdict === 'mid') { vb.className='verdict-badge verdict-mid'; vb.textContent='⚠️ Moderate'; }
  else { vb.className='verdict-badge verdict-bad'; vb.textContent='❌ Risky'; }

  // Score ring animation
  const scoreEl = document.getElementById('r-score');
  const circle  = document.getElementById('scoreCircle');
  const circumference = 213.6;
  const scoreColor = data.score >= 70 ? '#00C9A7' : data.score >= 50 ? '#FFD166' : '#FF5C5C';
  circle.style.stroke = scoreColor;
  scoreEl.style.color = scoreColor;
  let s = 0;
  const target = data.score;
  const interval = setInterval(() => {
    s = Math.min(s+2, target);
    scoreEl.textContent = s;
    circle.style.strokeDashoffset = circumference - (circumference * s / 100);
    if (s >= target) clearInterval(interval);
  }, 18);

  document.getElementById('r-score-label').textContent =
    data.score >= 70 ? 'High potential product' : data.score >= 50 ? 'Moderate potential' : 'Low potential — consider alternatives';
  document.getElementById('r-score-desc').textContent =
    data.score >= 70 ? 'Strong market demand, healthy margins, and manageable competition.' :
    data.score >= 50 ? 'Some potential but significant challenges to overcome.' :
    'This product faces difficult competition or low margins.';

  // Metrics
  document.getElementById('r-demand').textContent = data.demand;
  document.getElementById('r-competition').textContent = data.competition;
  document.getElementById('r-margin').textContent = data.margin;
  document.getElementById('r-price').textContent = data.price;
  document.getElementById('r-audience').textContent = data.audience;
  document.getElementById('r-trend').textContent = data.trend;

  // Risks
  const riskList = document.getElementById('r-risks');
  riskList.innerHTML = data.risks.map(r =>
    `<li><span class="ri">⚠️</span>${r}</li>`
  ).join('');

  // Ads (premium gate for free users)
  const adsContent = document.getElementById('ads-content');
  if (isPremium) {
    adsContent.innerHTML = `
      <div style="display:flex;flex-direction:column;gap:.8rem">
        ${adBlock('Facebook / Instagram','📘', data.adFacebook)}
        ${adBlock('TikTok','🎵', data.adTiktok)}
        ${adBlock('Instagram Caption','📷', data.adInstagram)}
      </div>`;
  } else {
    adsContent.innerHTML = `
      <div class="premium-gate">
        <h4>🔒 AI Ad Ideas — Premium Feature</h4>
        <p>Unlock ready-made ad copy for Facebook, TikTok, and Instagram. Just copy, paste, and launch.</p>
        <button class="unlock-btn" onclick="openModal()">⭐ Unlock Premium — $9/month</button>
      </div>`;
  }

  // Strategy (premium gate)
  const stratContent = document.getElementById('strategy-content');
  if (isPremium) {
    stratContent.innerHTML = `
      <ul class="strat-list">
        ${data.strategies.map(s=>`<li><span class="ri">🎯</span>${s}</li>`).join('')}
      </ul>`;
  } else {
    stratContent.innerHTML = `
      <div class="premium-gate">
        <h4>🔒 Strategy Playbook — Premium Feature</h4>
        <p>Get a step-by-step action plan with targeting strategies, scaling tactics, and competitor insights.</p>
        <button class="unlock-btn" onclick="openModal()">⭐ Unlock Premium — $9/month</button>
      </div>`;
  }

  switchTab('overview', document.querySelector('.rtab'));
  document.getElementById('result-panel').classList.add('show');
  document.getElementById('result-panel').scrollIntoView({ behavior:'smooth', block:'nearest' });
}

function adBlock(platform, icon, copy) {
  const id = 'ad_'+Math.random().toString(36).slice(2,7);
  return `<div class="ad-block">
    <div class="ad-platform">${icon} ${platform}</div>
    <div class="ad-copy" id="${id}">${copy}</div>
    <button class="copy-btn" onclick="copyAd('${id}',this)">Copy</button>
  </div>`;
}

function copyAd(id, btn) {
  const text = document.getElementById(id).textContent;
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = '✓ Copied'; btn.classList.add('copied');
    setTimeout(()=>{ btn.textContent='Copy'; btn.classList.remove('copied'); },2000);
  });
}

function switchTab(tabId, btn) {
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.rtab').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+tabId).classList.add('active');
  if (btn) btn.classList.add('active');
}

function resetAnalyzer() {
  document.getElementById('productInput').value = '';
  document.getElementById('result-panel').classList.remove('show');
  document.getElementById('productInput').focus();
  window.scrollTo({top:0, behavior:'smooth'});
}

function fillExample(text) {
  document.getElementById('productInput').value = text;
  document.getElementById('productInput').focus();
  showToast('💡 Example loaded — click Analyze!','info');
}

// ── MODAL ──
function openModal() { document.getElementById('premiumModal').classList.add('open'); }
function closeModal() { document.getElementById('premiumModal').classList.remove('open'); }
document.getElementById('premiumModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

function handleSubscribe() {
  closeModal();
  isPremium = true;
  document.getElementById('creditsLeft').textContent = '∞';
  document.querySelector('.credits-info').innerHTML = '⭐ Premium plan — <span style="color:var(--gold)">Unlimited analyses</span>';
  showToast('🎉 Welcome to Premium! All features unlocked.','success');
  // Re-render current result if exists
  const panel = document.getElementById('result-panel');
  if (panel.classList.contains('show')) {
    const input = document.getElementById('productInput').value;
    const data = getAnalysisData(input);
    renderResult(data, input);
  }
}

// ── EMAIL FORM ──
function handleEmailSubmit() {
  const email = document.getElementById('emailInput').value.trim();
  if (!email || !email.includes('@')) {
    showToast('⚠️ Please enter a valid email address','error'); return;
  }
  document.getElementById('emailForm').style.display = 'none';
  document.getElementById('emailSuccess').classList.add('show');
  showToast('🎉 You\'re on the list!','success');
}

// ── TOAST ──
function showToast(msg, type='info') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = `toast ${type} show`;
  setTimeout(()=>t.classList.remove('show'), 3200);
}

// ── SCROLL REVEAL ──
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.style.opacity='1'; e.target.style.transform='translateY(0)';
    }
  });
},{threshold:0.1});
document.querySelectorAll('.step-card,.feature-card,.testimonial-card,.pricing-card,.benefit-item,.stat-item').forEach(el=>{
  el.style.opacity='0'; el.style.transform='translateY(24px)';
  el.style.transition='opacity .5s ease,transform .5s ease';
  observer.observe(el);
});

// ── NAV ACTIVE ──
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('.nav-links a');
window.addEventListener('scroll',()=>{
  let current='';
  sections.forEach(s=>{ if(window.scrollY>=s.offsetTop-120) current=s.id; });
  navLinks.forEach(a=>{ a.style.color=a.getAttribute('href')==='#'+current?'#F0F2FF':''; });
});

// ── ENTER KEY ──
document.getElementById('productInput').addEventListener('keydown',e=>{
  if(e.key==='Enter') startAnalysis();
});
</script>
